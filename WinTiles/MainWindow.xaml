<Window x:Class="WinTiles.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WinTiles"
        Icon="Assets/WinTiles.ico"
        Width="1512"
        Height="1018"
        MinWidth="1280"
        MinHeight="860"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid SnapsToDevicePixels="True">
        <Ellipse Width="720"
                 Height="720"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-250,-260,0,0"
                 Fill="#CDE0FF"
                 Opacity="0.42" />
        <Ellipse Width="820"
                 Height="820"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-300,-280"
                 Fill="#E3EEFF"
                 Opacity="0.60" />

        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ShellCardStyle}"
                    Padding="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <!-- 这里改成使用单独的高分辨率品牌图，避免直接显示 ico 时在界面里发糊。 -->
                        <Border Width="90"
                                Height="90"
                                CornerRadius="26"
                                Background="Transparent">
                            <Image Source="Assets/BrandPanelImage.png"
                                   Stretch="Uniform" />
                        </Border>

                        <StackPanel Margin="18,6,0,0">
                            <TextBlock FontSize="40"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       Text="WinTiles" />
                            <TextBlock Margin="0,12,0,0"
                                       Width="240"
                                       FontSize="16"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="把一张图片拆成多个开始菜单磁贴，按你的裁切布局依次固定。"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,30,0,0">
                        <!-- 左侧主操作改成纯文字按钮，减少图标带来的视觉重量差异。 -->
                        <Button x:Name="SelectImageButton"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Click="SelectImageButton_Click">
                            <TextBlock Style="{StaticResource ActionButtonTextStyle}"
                                       Text="选择图片" />
                        </Button>

                        <Button x:Name="PinImageButton"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="PinImageButton_Click"
                                IsEnabled="{Binding CanPinImage}">
                            <TextBlock Style="{StaticResource ActionButtonTextStyle}"
                                       Text="固定图片" />
                        </Button>

                        <Button x:Name="ShowHistoryButton"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="ShowHistoryButton_Click"
                                IsEnabled="{Binding CanOpenHistory}">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource ActionButtonTextStyle}"
                                           Text="固定历史" />

                                <Border Margin="12,0,0,0"
                                        Padding="10,6"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource PrimaryAccentSoftBrush}"
                                        BorderBrush="#D6E4FB"
                                        BorderThickness="1"
                                        CornerRadius="999">
                                    <TextBlock FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource PrimaryAccentBrush}"
                                               Text="{Binding HistoryCountText}" />
                                </Border>
                            </StackPanel>
                        </Button>

                        <Button x:Name="CheckForUpdatesButton"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="CheckForUpdatesButton_Click"
                                IsEnabled="{Binding CanCheckForUpdates}">
                            <TextBlock Style="{StaticResource ActionButtonTextStyle}"
                                       Text="检查更新" />
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="3"
                            Padding="14,12"
                            Background="{StaticResource InfoSoftBrush}"
                            BorderBrush="{StaticResource InfoBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10"
                                         Height="10"
                                         Margin="0,7,10,0"
                                         Fill="{Binding AvailabilityBrush}" />
                                <TextBlock Text="{Binding AvailabilityMessage}"
                                           Foreground="{Binding AvailabilityBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Margin="20,8,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{Binding UpdateStatusText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource ShellCardStyle}"
                    Padding="28">
                <Grid>
                    <Grid Visibility="{Binding IsCropMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <StackPanel>
                                <TextBlock FontSize="26"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           Text="预览区 · 图片裁切" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="15"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="{Binding CropSubtitle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1"
                              Margin="0,24,0,0">
                            <Border
                                    Padding="18"
                                    Background="{StaticResource InsetSurfaceBrush}"
                                    BorderBrush="{StaticResource InsetBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <Border.Resources>
                                    <Style x:Key="CropAxisToggleButtonStyle"
                                           TargetType="Button">
                                        <Setter Property="Width"
                                                Value="28" />
                                        <Setter Property="Height"
                                                Value="28" />
                                        <Setter Property="Padding"
                                                Value="0" />
                                        <Setter Property="BorderThickness"
                                                Value="0" />
                                        <Setter Property="Background"
                                                Value="Transparent" />
                                        <Setter Property="Foreground"
                                                Value="{StaticResource PrimaryAccentBrush}" />
                                        <Setter Property="Cursor"
                                                Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="ButtonBorder"
                                                            Background="#F3F8FFFF"
                                                            BorderBrush="#C8DAF6"
                                                            BorderThickness="1"
                                                            CornerRadius="999">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          RecognizesAccessKey="True"
                                                                          TextElement.FontSize="18"
                                                                          TextElement.FontWeight="SemiBold"
                                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter TargetName="ButtonBorder"
                                                                    Property="BorderBrush"
                                                                    Value="#6BA7FF" />
                                                            <Setter TargetName="ButtonBorder"
                                                                    Property="Background"
                                                                    Value="#E8F1FFFF" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                            <Setter TargetName="ButtonBorder"
                                                                    Property="Background"
                                                                    Value="#D7E8FFFF" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled"
                                                                 Value="False">
                                                            <Setter TargetName="ButtonBorder"
                                                                    Property="Opacity"
                                                                    Value="0.42" />
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}"
                                                                     Value="True">
                                                            <Setter Property="Foreground"
                                                                    Value="White" />
                                                            <Setter TargetName="ButtonBorder"
                                                                    Property="Background"
                                                                    Value="#2F7DFF" />
                                                            <Setter TargetName="ButtonBorder"
                                                                    Property="BorderBrush"
                                                                    Value="#6BA7FF" />
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Border.Resources>

                                <Grid x:Name="CropBoardHost"
                                      ClipToBounds="True"
                                      SizeChanged="CropBoardHost_SizeChanged">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <ItemsControl Grid.Row="0"
                                                  Grid.Column="1"
                                                  Width="{Binding CropColumnControlWidth}"
                                                  Height="28"
                                                  Margin="0,0,0,6"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Bottom"
                                                  ItemsSource="{Binding CropColumnControls}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left"
                                                        Value="{Binding Left}" />
                                                <Setter Property="Canvas.Top"
                                                        Value="{Binding Top}" />
                                                <Setter Property="Visibility"
                                                        Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVisible}"
                                                                 Value="False">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource CropAxisToggleButtonStyle}"
                                                        Click="CropColumnControlButton_Click"
                                                        Content="{Binding Symbol}"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        Tag="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <ItemsControl Grid.Row="1"
                                                  Grid.Column="0"
                                                  Width="28"
                                                  Height="{Binding CropRowControlHeight}"
                                                  Margin="0,0,6,0"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  ItemsSource="{Binding CropRowControls}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left"
                                                        Value="{Binding Left}" />
                                                <Setter Property="Canvas.Top"
                                                        Value="{Binding Top}" />
                                                <Setter Property="Visibility"
                                                        Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVisible}"
                                                                 Value="False">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource CropAxisToggleButtonStyle}"
                                                        Click="CropRowControlButton_Click"
                                                        Content="{Binding Symbol}"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        Tag="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border x:Name="CropBoardBorder"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Width="{Binding CropBoardWidth}"
                                            Height="{Binding CropBoardHeight}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#EEF5FD"
                                            BorderBrush="#D5E1F0"
                                            BorderThickness="1"
                                            CornerRadius="0"
                                            ClipToBounds="True"
                                            Cursor="SizeAll"
                                            MouseLeftButtonDown="CropBoardBorder_MouseLeftButtonDown"
                                            MouseLeftButtonUp="CropBoardBorder_MouseLeftButtonUp"
                                            MouseMove="CropBoardBorder_MouseMove"
                                            MouseLeave="CropBoardBorder_MouseLeave"
                                            PreviewMouseWheel="CropBoardBorder_PreviewMouseWheel">
                                        <Grid Background="#EEF5FD">
                                            <Canvas x:Name="CropImageCanvas"
                                                    ClipToBounds="True">
                                                <Image x:Name="CropImageElement"
                                                       Source="{Binding CropImage}"
                                                       Stretch="Fill"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.RenderTransform>
                                                        <TransformGroup>
                                                            <ScaleTransform x:Name="CropImageScaleTransform" />
                                                            <TranslateTransform x:Name="CropImageTranslateTransform" />
                                                        </TransformGroup>
                                                    </Image.RenderTransform>
                                                </Image>
                                            </Canvas>

                                            <ItemsControl x:Name="CropCellsOverlaySource"
                                                          ItemsSource="{Binding CropCells}"
                                                          IsHitTestVisible="False">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left"
                                                                Value="{Binding Left}" />
                                                        <Setter Property="Canvas.Top"
                                                                Value="{Binding Top}" />
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVisible}"
                                                                         Value="False">
                                                                <Setter Property="Visibility"
                                                                        Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Width="{Binding Size}"
                                                              Height="{Binding Size}">
                                                            <Rectangle x:Name="InactiveCell"
                                                                       Fill="#F9FCFFDD"
                                                                       Stroke="#C9D8EC"
                                                                       StrokeThickness="1.5"
                                                                       StrokeDashArray="7 5" />
                                                            <Border x:Name="ActiveCell"
                                                                    Background="#1E2F7DFF"
                                                                    BorderBrush="#6BA7FF"
                                                                    BorderThickness="2"
                                                                    Visibility="Collapsed" />
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}"
                                                                         Value="True">
                                                                <Setter TargetName="InactiveCell"
                                                                        Property="Visibility"
                                                                        Value="Collapsed" />
                                                                <Setter TargetName="ActiveCell"
                                                                        Property="Visibility"
                                                                        Value="Visible" />
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Grid IsHitTestVisible="False">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCropImage}"
                                                                         Value="True">
                                                                <Setter Property="Visibility"
                                                                        Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <!-- 空状态下让整块裁切板呈现类似 Windows 11 亚克力的覆盖层，并保留底层网格的模糊轮廓。 -->
                                                <Grid>
                                                    <Rectangle>
                                                        <Rectangle.Fill>
                                                            <VisualBrush Visual="{Binding ElementName=CropCellsOverlaySource}"
                                                                         Stretch="Fill" />
                                                        </Rectangle.Fill>
                                                        <Rectangle.Effect>
                                                            <BlurEffect Radius="24"
                                                                        RenderingBias="Quality" />
                                                        </Rectangle.Effect>
                                                    </Rectangle>
                                                    <Rectangle>
                                                        <Rectangle.Fill>
                                                            <LinearGradientBrush StartPoint="0,0"
                                                                                 EndPoint="1,1">
                                                                <GradientStop Offset="0"
                                                                              Color="#F2FAFFFF" />
                                                                <GradientStop Offset="0.42"
                                                                              Color="#E9F5FFEE" />
                                                                <GradientStop Offset="1"
                                                                              Color="#D9EDFCDD" />
                                                            </LinearGradientBrush>
                                                        </Rectangle.Fill>
                                                    </Rectangle>
                                                    <Border Background="#12FFFFFF"
                                                            BorderBrush="#A8FFFFFF"
                                                            BorderThickness="1" />
                                                    <Border Margin="10"
                                                            Background="#14FFFFFF"
                                                            BorderBrush="#34FFFFFF"
                                                            BorderThickness="1" />

                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <Border Width="92"
                                                                Height="92"
                                                                HorizontalAlignment="Center"
                                                                Background="#CCEEF5FF"
                                                                BorderBrush="#C8FFFFFF"
                                                                BorderThickness="1"
                                                                CornerRadius="26">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="18"
                                                                                  ShadowDepth="0"
                                                                                  Color="#1A4A7CCF"
                                                                                  Opacity="0.28" />
                                                            </Border.Effect>
                                                            <Viewbox Margin="20">
                                                                <Canvas Width="24"
                                                                        Height="24">
                                                                    <Rectangle Width="19"
                                                                               Height="14"
                                                                               Canvas.Left="2.5"
                                                                               Canvas.Top="4.5"
                                                                               RadiusX="2.8"
                                                                               RadiusY="2.8"
                                                                               Stroke="{StaticResource PrimaryAccentBrush}"
                                                                               StrokeThickness="1.5"
                                                                               Fill="Transparent" />
                                                                    <Ellipse Width="3"
                                                                             Height="3"
                                                                             Canvas.Left="6"
                                                                             Canvas.Top="7"
                                                                             Fill="{StaticResource PrimaryAccentBrush}" />
                                                                    <Polyline Points="5,16 9.8,11.2 13,14.2 16.3,10.6 20,16"
                                                                              Stroke="{StaticResource PrimaryAccentBrush}"
                                                                              StrokeThickness="1.8"
                                                                              StrokeStartLineCap="Round"
                                                                              StrokeEndLineCap="Round"
                                                                              StrokeLineJoin="Round" />
                                                                </Canvas>
                                                            </Viewbox>
                                                        </Border>
                                                        <TextBlock Margin="0,18,0,0"
                                                                   HorizontalAlignment="Center"
                                                                   FontSize="22"
                                                                   FontWeight="Medium"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   Text="选择图片，预览裁切效果" />
                                                        <TextBlock Margin="0,10,0,0"
                                                                   Width="340"
                                                                   HorizontalAlignment="Center"
                                                                   FontSize="15"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   Text="点击选择图片后，可通过顶部列按钮和左侧行按钮调整裁切范围，再在这里缩放与拖拽图片。"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Margin="0,20,0,0"
                                Padding="18"
                                Background="{StaticResource InsetSurfaceBrush}"
                                BorderBrush="{StaticResource InsetBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24">
                            <StackPanel>
                                <TextBlock FontSize="18"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           Text="点击动作" />
                                <StackPanel Margin="0,12,0,0"
                                            Orientation="Horizontal">
                                    <RadioButton GroupName="TileClickActionGroup"
                                                 Margin="0,0,16,0"
                                                 VerticalAlignment="Center"
                                                 IsChecked="{Binding IsNoClickActionSelected, Mode=OneWay}"
                                                 Checked="NoClickActionRadioButton_Checked"
                                                 Content="不设置" />
                                    <RadioButton GroupName="TileClickActionGroup"
                                                 Margin="0,0,16,0"
                                                 VerticalAlignment="Center"
                                                 IsChecked="{Binding IsOpenUrlActionSelected, Mode=OneWay}"
                                                 Checked="OpenUrlActionRadioButton_Checked"
                                                 Content="打开网页" />
                                    <RadioButton GroupName="TileClickActionGroup"
                                                 VerticalAlignment="Center"
                                                 IsChecked="{Binding IsOpenApplicationActionSelected, Mode=OneWay}"
                                                 Checked="OpenApplicationActionRadioButton_Checked"
                                                 Content="打开应用" />
                                </StackPanel>

                                <StackPanel Margin="0,12,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOpenUrlActionSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontSize="13"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="网页地址" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="12,8"
                                             FontSize="14"
                                             Text="{Binding ClickActionUrl, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="ClickActionInputChanged" />
                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="仅支持 http:// 或 https:// 链接。"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Margin="0,12,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOpenApplicationActionSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <StackPanel.Resources>
                                        <!-- 为“打开应用”表单单独收紧按钮和输入框尺寸，避免沿用左侧大按钮样式后显得过于笨重。 -->
                                        <Style x:Key="CompactActionButtonStyle"
                                               TargetType="Button"
                                               BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Padding" Value="12,8" />
                                            <Setter Property="MinHeight" Value="42" />
                                            <Setter Property="FontSize" Value="14" />
                                        </Style>

                                        <Style x:Key="CompactActionButtonTextStyle"
                                               TargetType="TextBlock"
                                               BasedOn="{StaticResource ActionButtonTextStyle}">
                                            <Setter Property="FontSize" Value="14" />
                                        </Style>

                                        <Style x:Key="CompactActionTextBoxStyle" TargetType="TextBox">
                                            <Setter Property="Padding" Value="10,7" />
                                            <Setter Property="FontSize" Value="14" />
                                            <Setter Property="MinHeight" Value="40" />
                                        </Style>
                                    </StackPanel.Resources>

                                    <!-- 这里进一步改成三列同一行表单，把应用路径、启动参数和工作目录并排展示，继续压缩纵向空间。 -->
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.35*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="0.95*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="1.15*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="12"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Text="应用路径" />
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="96" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Style="{StaticResource CompactActionTextBoxStyle}"
                                                         Text="{Binding ClickActionApplicationPath, UpdateSourceTrigger=PropertyChanged}"
                                                         TextChanged="ClickActionInputChanged" />
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource CompactActionButtonStyle}"
                                                        Click="BrowseApplicationPathButton_Click">
                                                    <TextBlock Style="{StaticResource CompactActionButtonTextStyle}"
                                                               Text="浏览" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock FontSize="12"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Text="启动参数" />
                                            <TextBox Margin="0,6,0,0"
                                                     Style="{StaticResource CompactActionTextBoxStyle}"
                                                     Text="{Binding ClickActionArguments, UpdateSourceTrigger=PropertyChanged}"
                                                     TextChanged="ClickActionInputChanged" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock FontSize="12"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Text="工作目录" />
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="108" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Style="{StaticResource CompactActionTextBoxStyle}"
                                                         Text="{Binding ClickActionWorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                         TextChanged="ClickActionInputChanged" />
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource CompactActionButtonStyle}"
                                                        Click="UseApplicationDirectoryButton_Click">
                                                    <TextBlock Style="{StaticResource CompactActionButtonTextStyle}"
                                                               Text="应用目录" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="工作目录留空时默认使用应用所在目录；需要特殊启动环境时，再手动指定。"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Margin="0,12,0,0"
                                        Padding="10,8"
                                        Background="{StaticResource PrimaryAccentSoftBrush}"
                                        BorderBrush="#D6E4FB"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Text="动作摘要预览" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Text="{Binding ClickActionSummaryText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="12"
                                                   Foreground="{Binding ClickActionValidationBrush}"
                                                   Text="{Binding ClickActionValidationText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Visibility="{Binding IsHistoryMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="26"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           Text="固定历史" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="15"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="按批次查看这一轮裁切固定的结果；展开后可以删除单块，也可以整批清理。"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="18,0,0,0"
                                        Orientation="Horizontal">
                                <Button x:Name="BackToCropButton"
                                        Width="138"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Click="BackToCropButton_Click">
                                    <TextBlock Style="{StaticResource ActionButtonTextStyle}"
                                               Text="返回裁切" />
                                </Button>
                                <Button x:Name="OpenRecordFolderButton"
                                        Width="148"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Click="OpenRecordFolderButton_Click"
                                        IsEnabled="{Binding CanOpenRecordFolder}">
                                    <TextBlock Style="{StaticResource ActionButtonTextStyle}"
                                               Text="打开记录目录" />
                                </Button>
                                <Button x:Name="ClearAllPinnedTilesButton"
                                        Width="176"
                                        MinHeight="64"
                                        Padding="18,16"
                                        Style="{StaticResource DangerActionButtonStyle}"
                                        Click="ClearAllPinnedTilesButton_Click"
                                        IsEnabled="{Binding CanClearAllPinnedTiles}">
                                    <TextBlock Style="{StaticResource ActionButtonTextStyle}"
                                               Text="清除全部固定" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,24,0,0"
                                Style="{StaticResource InsetCardStyle}"
                                Padding="18"
                                ClipToBounds="True">
                            <Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding HasHistoryItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding BatchHistoryItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,16"
                                                        Padding="16"
                                                        Background="#FCFEFF"
                                                        BorderBrush="#DAE5F3"
                                                        BorderThickness="1"
                                                        CornerRadius="24">
                                                    <Expander IsExpanded="{Binding IsExpanded}"
                                                              Background="Transparent"
                                                              BorderThickness="0">
                                                        <Expander.Header>
                                                            <Grid Margin="0,0,10,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="82" />
                                                                    <ColumnDefinition Width="14" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="18" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <Border Width="82"
                                                                        Height="82"
                                                                        Background="{StaticResource PrimaryAccentSoftBrush}"
                                                                        BorderBrush="#D5E3FB"
                                                                        BorderThickness="1"
                                                                        CornerRadius="20"
                                                                        ClipToBounds="True">
                                                                    <Grid>
                                                                        <Image Source="{Binding ThumbnailImage}"
                                                                               Stretch="UniformToFill"
                                                                               Visibility="Visible">
                                                                            <Image.Style>
                                                                                <Style TargetType="Image">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasThumbnailImage}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Image.Style>
                                                                        </Image>
                                                                        <TextBlock HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   FontSize="16"
                                                                                   FontWeight="Medium"
                                                                                   Foreground="{StaticResource PrimaryAccentBrush}"
                                                                                   Text="图片">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasThumbnailImage}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Grid>
                                                                </Border>

                                                                <StackPanel Grid.Column="2"
                                                                            VerticalAlignment="Center">
                                                                    <TextBlock FontSize="18"
                                                                               FontWeight="Medium"
                                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                                               Text="{Binding DisplayTitle}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               FontSize="13"
                                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                                               Text="{Binding AttemptedAtText}" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               FontSize="13"
                                                                               Foreground="{Binding SummaryBrush}"
                                                                               Text="{Binding SummaryText}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               FontSize="13"
                                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                                               Text="{Binding ActionSummaryText}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="4"
                                                                            VerticalAlignment="Center">
                                                                    <Border Padding="12,8"
                                                                            Margin="0,0,0,8"
                                                                            Background="{StaticResource PrimaryAccentSoftBrush}"
                                                                            BorderBrush="#D6E4FB"
                                                                            BorderThickness="1"
                                                                            CornerRadius="999">
                                                                        <TextBlock FontSize="13"
                                                                                   FontWeight="Medium"
                                                                                   Foreground="{StaticResource PrimaryAccentBrush}"
                                                                                   Text="{Binding TileCountText}" />
                                                                    </Border>
                                                                    <TextBlock HorizontalAlignment="Right"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                                               Text="{Binding SuccessCount, StringFormat=成功 {0} 块}" />
                                                                    <TextBlock HorizontalAlignment="Right"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource DangerBrush}"
                                                                               Text="{Binding FailureCount, StringFormat=失败 {0} 块}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Expander.Header>

                                                        <StackPanel Margin="0,16,0,0">
                                                            <ItemsControl ItemsSource="{Binding Tiles}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Margin="0,0,0,12"
                                                                                Padding="14"
                                                                                Background="{StaticResource InsetSurfaceBrush}"
                                                                                BorderBrush="{StaticResource InsetBorderBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="20">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="72" />
                                                                                    <ColumnDefinition Width="14" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="14" />
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>

                                                                                <Border Width="72"
                                                                                        Height="72"
                                                                                        Background="{StaticResource PrimaryAccentSoftBrush}"
                                                                                        BorderBrush="#D5E3FB"
                                                                                        BorderThickness="1"
                                                                                        CornerRadius="18"
                                                                                        ClipToBounds="True">
                                                                                    <Grid>
                                                                                        <Image Source="{Binding ThumbnailImage}"
                                                                                               Stretch="UniformToFill"
                                                                                               Visibility="Visible">
                                                                                            <Image.Style>
                                                                                                <Style TargetType="Image">
                                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding HasThumbnailImage}" Value="False">
                                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </Image.Style>
                                                                                        </Image>
                                                                                        <TextBlock HorizontalAlignment="Center"
                                                                                                   VerticalAlignment="Center"
                                                                                                   FontSize="14"
                                                                                                   FontWeight="Medium"
                                                                                                   Foreground="{StaticResource PrimaryAccentBrush}"
                                                                                                   Text="预览">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding HasThumbnailImage}" Value="False">
                                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                    </Grid>
                                                                                </Border>

                                                                                <StackPanel Grid.Column="2"
                                                                                            VerticalAlignment="Center">
                                                                                    <TextBlock FontSize="16"
                                                                                               FontWeight="Medium"
                                                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                                                               Text="{Binding GridPositionText}" />
                                                                                    <TextBlock Margin="0,4,0,0"
                                                                                               FontSize="13"
                                                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                                                               Text="{Binding AttemptedAtText}" />
                                                                                    <TextBlock Margin="0,6,0,0"
                                                                                               FontSize="13"
                                                                                               Foreground="{Binding DetailBrush}"
                                                                                               Text="{Binding DetailText}"
                                                                                               TextWrapping="Wrap" />
                                                                                    <TextBlock Margin="0,6,0,0"
                                                                                               FontSize="13"
                                                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                                                               Text="{Binding ActionDetailText}"
                                                                                               TextWrapping="Wrap" />
                                                                                </StackPanel>

                                                                                <Button Grid.Column="4"
                                                                                        Width="132"
                                                                                        Style="{StaticResource DangerActionButtonStyle}"
                                                                                        Click="DeleteTileButton_Click"
                                                                                        Tag="{Binding}">
                                                                                    <TextBlock HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"
                                                                                               Text="删除单块" />
                                                                                </Button>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <Button Width="160"
                                                                    HorizontalAlignment="Right"
                                                                    Style="{StaticResource DangerActionButtonStyle}"
                                                                    Click="DeleteBatchButton_Click"
                                                                    Tag="{Binding}">
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Text="删除这一批" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Expander>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasHistoryItems}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Width="92"
                                            Height="92"
                                            HorizontalAlignment="Center"
                                            Background="{StaticResource PrimaryAccentSoftBrush}"
                                            BorderBrush="#D5E3FB"
                                            BorderThickness="1"
                                            CornerRadius="26">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="28"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource PrimaryAccentBrush}"
                                                   Text="历史" />
                                    </Border>
                                    <TextBlock Margin="0,18,0,0"
                                               HorizontalAlignment="Center"
                                               FontSize="22"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               Text="尚未固定历史" />
                                    <TextBlock Margin="0,10,0,0"
                                               Width="340"
                                               HorizontalAlignment="Center"
                                               FontSize="15"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="完成一次图片固定后，这里会按批次显示结果；展开后可以清理单块或整批。"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
