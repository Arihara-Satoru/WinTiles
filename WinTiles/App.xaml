<Application x:Class="WinTiles.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore">
    <Application.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FDFEFF" Offset="0" />
            <GradientStop Color="#F3F7FD" Offset="0.55" />
            <GradientStop Color="#EBF2FA" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="SurfaceBrush" Color="#FAFCFF" />
        <SolidColorBrush x:Key="InsetSurfaceBrush" Color="#F5F9FE" />
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#DEE8F4" />
        <SolidColorBrush x:Key="InsetBorderBrush" Color="#D6E2F0" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#13212F" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#68788D" />
        <SolidColorBrush x:Key="TertiaryTextBrush" Color="#8A97A8" />
        <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#2F7DFF" />
        <SolidColorBrush x:Key="PrimaryAccentHoverBrush" Color="#266BE2" />
        <SolidColorBrush x:Key="PrimaryAccentSoftBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#1A8F5F" />
        <SolidColorBrush x:Key="WarningBrush" Color="#C6901A" />
        <SolidColorBrush x:Key="DangerBrush" Color="#D9455D" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#FFF1F4" />
        <SolidColorBrush x:Key="InfoSoftBrush" Color="#F6FAFF" />
        <SolidColorBrush x:Key="InfoBorderBrush" Color="#DDE8F6" />

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <effects:DropShadowEffect x:Key="PanelShadowEffect"
                                  BlurRadius="28"
                                  Color="#35618A"
                                  Direction="270"
                                  Opacity="0.14"
                                  ShadowDepth="8" />

        <effects:DropShadowEffect x:Key="ButtonShadowEffect"
                                  BlurRadius="20"
                                  Color="#1D5B9E"
                                  Direction="270"
                                  Opacity="0.20"
                                  ShadowDepth="5" />

        <Style x:Key="ShellCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="30" />
            <Setter Property="Effect" Value="{StaticResource PanelShadowEffect}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="InsetCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource InsetSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InsetBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="BaseActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.97" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.99" ScaleY="0.99" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource BaseActionButtonStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#60A4FF" Offset="0" />
                        <GradientStop Color="#2F7DFF" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#2C74EF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Effect" Value="{StaticResource ButtonShadowEffect}" />
        </Style>

        <Style x:Key="SecondaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource BaseActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="DangerActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource BaseActionButtonStyle}">
            <Setter Property="MinHeight" Value="58" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
            <Setter Property="BorderBrush" Value="#F1C4CD" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
        </Style>

        <!-- 统一按钮正文的字重和字号，避免同一区域出现粗细不一致的观感。 -->
        <Style x:Key="ActionButtonTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="IconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource BaseActionButtonStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
        </Style>
    </Application.Resources>
</Application>
