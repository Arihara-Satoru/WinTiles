<Application x:Class="WinTiles.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F8FC" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#E3ECF7" />
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#2F7DFF" />
        <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#286FE3" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6F7E95" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
