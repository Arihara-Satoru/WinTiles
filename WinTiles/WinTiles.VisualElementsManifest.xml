<?xml version="1.0" encoding="utf-8"?>
<Application xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <!-- 给 WinTiles.exe 自身提供桌面应用磁贴资源，避免开始菜单只回退到居中的小图标。 -->
  <VisualElements
    BackgroundColor="#2F7DFF"
    ForegroundText="light"
    ShowNameOnSquare150x150Logo="off"
    ShowNameOnWide310x150Logo="off"
    Square70x70Logo="TileAssets\Square70x70Logo.png"
    Square150x150Logo="TileAssets\Square150x150Logo.png"
    Wide310x150Logo="TileAssets\Wide310x150Logo.png"
    Square310x310Logo="TileAssets\Square310x310Logo.png">
    <DefaultTile
      DefaultSize="square150x150Logo"
      Square70x70Logo="TileAssets\Square70x70Logo.png"
      Wide310x150Logo="TileAssets\Wide310x150Logo.png"
      Square310x310Logo="TileAssets\Square310x310Logo.png" />
  </VisualElements>
</Application>
